+
+def _skew(v):
+    zero = torch.zeros_like(v[..., 0])
+    return torch.stack(
+        [
+            torch.stack([zero, -v[..., 2], v[..., 1]], dim=-1),
+            torch.stack([v[..., 2], zero, -v[..., 0]], dim=-1),
+            torch.stack([-v[..., 1], v[..., 0], zero], dim=-1),
+        ],
+        dim=-2,
+    )
+
+def _axis_angle_to_matrix(axis_angle):
+    theta = torch.linalg.norm(axis_angle, dim=-1, keepdim=True).clamp_min(1e-8)
+    axis = axis_angle / theta
+    k = _skew(axis)
+    eye = torch.eye(3, dtype=axis_angle.dtype, device=axis_angle.device).expand(axis_angle.shape[:-1] + (3, 3))
+    sin = torch.sin(theta)[..., None]
+    cos = torch.cos(theta)[..., None]
+    return eye + sin * k + (1.0 - cos) * torch.matmul(k, k)
+
+class JointPoseAdapter(torch.nn.Module):
+    def __init__(self, train_cameras, lr_rot, lr_trans, max_rot, max_trans):
+        super().__init__()
+        self.rot = torch.nn.Parameter(torch.zeros(len(train_cameras), 3, device="cuda"))
+        self.trans = torch.nn.Parameter(torch.zeros(len(train_cameras), 3, device="cuda"))
+        self.max_rot = float(max_rot)
+        self.max_trans = float(max_trans)
+        self.lr_rot = float(lr_rot)
+        self.lr_trans = float(lr_trans)
+        for cam in train_cameras:
+            cam.base_world_view_transform = cam.world_view_transform.detach().clone()
+            cam.base_full_proj_transform = cam.full_proj_transform.detach().clone()
+            cam.base_camera_center = cam.camera_center.detach().clone()
+
+    def parameter_groups(self):
+        return [
+            {"params": [self.rot], "lr": self.lr_rot, "name": "joint_pose_rot"},
+            {"params": [self.trans], "lr": self.lr_trans, "name": "joint_pose_trans"},
+        ]
+
+    def regularization(self, index):
+        return (self.rot[index].square().mean() + self.trans[index].square().mean())
+
+    def apply(self, cam, index):
+        rotvec = self.rot[index].clamp(-self.max_rot, self.max_rot)
+        trans = self.trans[index].clamp(-self.max_trans, self.max_trans)
+        delta = torch.eye(4, dtype=cam.base_world_view_transform.dtype, device="cuda")
+        delta[:3, :3] = _axis_angle_to_matrix(rotvec)
+        delta[3, :3] = trans
+        cam.world_view_transform = cam.base_world_view_transform
+        cam.full_proj_transform = cam.base_full_proj_transform
+        cam.camera_center = cam.base_camera_center
+        cam.joint_pose_world_transform = cam.base_world_view_transform @ delta @ cam.base_world_view_transform.inverse()
+        return cam
